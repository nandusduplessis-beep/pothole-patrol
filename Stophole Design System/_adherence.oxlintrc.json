{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "grid-glyph.js",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|leadingIcon|trailingIcon|iconChip|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, leadingIcon, trailingIcon, iconChip, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|sunken|dark|yellow)$/]",
        "message": "<Card> variant must be one of 'default' | 'sunken' | 'dark' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DotScore'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|total|verdict|size|gap|key|ref|className|style|children)$/]",
        "message": "<DotScore> doesn't accept that prop. Declared props: score, total, verdict, size, gap."
      },
      {
        "selector": "JSXOpeningElement[name.name='DotScore'] > JSXAttribute[name.name='verdict'] > Literal[value!=/^(?:green|amber|red)$/]",
        "message": "<DotScore> verdict must be one of 'green' | 'amber' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:camera|map-pin|search|chevron-right|chevron-left|arrow-right|arrow-up-right|x|circle-check|circle-x|triangle-alert|user|vote|calendar|banknote|flag|phone|bell|plus|sun|moon|layers|share|home|list|message-square|settings)$/]",
        "message": "<Icon> name must be one of 'camera' | 'map-pin' | 'search' | 'chevron-right' | 'chevron-left' | 'arrow-right' | 'arrow-up-right' | 'x' | 'circle-check' | 'circle-x' | 'triangle-alert' | 'user' | 'vote' | 'calendar' | 'banknote' | 'flag' | 'phone' | 'bell' | 'plus' | 'sun' | 'moon' | 'layers' | 'share' | 'home' | 'list' | 'message-square' | 'settings'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PotholeInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|subtext|width|height|value|onSnap|onChange|children|key|ref|className|style|children)$/]",
        "message": "<PotholeInput> doesn't accept that prop. Declared props: placeholder, subtext, width, height, value, onSnap, onChange, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|tone|size|children|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, unit, tone, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|yellow|dark|soft)$/]",
        "message": "<StatTile> tone must be one of 'default' | 'yellow' | 'dark' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatTile> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|yellow|dark|success|danger)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'yellow' | 'dark' | 'success' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:verdict|size|label|key|ref|className|style|children)$/]",
        "message": "<VerdictBadge> doesn't accept that prop. Declared props: verdict, size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictBadge'] > JSXAttribute[name.name='verdict'] > Literal[value!=/^(?:green|amber|red)$/]",
        "message": "<VerdictBadge> verdict must be one of 'green' | 'amber' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<VerdictBadge> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
